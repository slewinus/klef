{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; [ -n \"$f\" ] && [[ \"$f\" == *.rs ]] && rustfmt \"$f\"; } 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "scripts/claude-line-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/claude-stop-check.sh"
          }
        ]
      }
    ]
  }
}
